{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        /* Language and Environment */
        "lib": ["ES2022"],

        /* Modules */
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowJs": true,
        "resolveJsonModule": true,

        /* Emit */
        "outDir": "dist/backend",
        "rootDir": "./src",

        /* Completeness */
        "types": ["express-session"]
    },
    "include": ["./src/backend"],
    "exclude": ["./src/frontend"],
}
