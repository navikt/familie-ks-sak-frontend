{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        /* Modules */
        "module": "esnext",
        "allowJs": true,
        "resolveJsonModule": true,

        /* Emit */
        "outDir": "backend",
        "rootDir": "./src",

        /* Completeness */
        "types": ["express-session"]
    },
    "include": ["./src/backend"],
    "exclude": ["./src/frontend"],
    "lib": ["es2015"]
}
